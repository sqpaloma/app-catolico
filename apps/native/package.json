{
  "name": "native",
  "version": "1.0.2",
  "private": true,
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "dev": "expo start --clear",
    "dev:tunnel": "expo start --tunnel --clear",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "prebuild": "expo prebuild",
    "web": "expo start --web",
    "version:patch": "node scripts/bump-version.mjs patch",
    "version:minor": "node scripts/bump-version.mjs minor",
    "version:major": "node scripts/bump-version.mjs major",
    "version:set": "node scripts/bump-version.mjs set",
    "release:patch": "npm run version:patch && npm run release:commit && npm run release:build",
    "release:minor": "npm run version:minor && npm run release:commit && npm run release:build",
    "release:major": "npm run version:major && npm run release:commit && npm run release:build",
    "release:commit": "node -e \"const v=require('./package.json').version;require('child_process').execSync('git add app.json package.json && git commit -m \\\"chore(release): v'+v+'\\\" && git tag v'+v,{stdio:'inherit'})\"",
    "release:build": "eas build --platform all --profile production --auto-submit --non-interactive"
  },
  "dependencies": {
    "@app-catolico/backend": "workspace:*",
    "@app-catolico/env": "workspace:*",
    "@clerk/clerk-expo": "^2.14.25",
    "@expo-google-fonts/xanh-mono": "^0.4.1",
    "@expo/metro-runtime": "~6.1.2",
    "@expo/vector-icons": "^15.0.3",
    "@gorhom/bottom-sheet": "^5",
    "@react-navigation/drawer": "^7.3.9",
    "@react-navigation/elements": "^2.8.1",
    "@sentry/react-native": "~7.2.0",
    "convex": "catalog:",
    "dotenv": "catalog:",
    "expo": "~54.0.33",
    "expo-auth-session": "~7.0.10",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.10",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-network": "~8.0.8",
    "expo-router": "~6.0.23",
    "expo-secure-store": "~15.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-web-browser": "~15.0.10",
    "heroui-native": "^1.0.0-rc.3",
    "lucide-react-native": "^1.7.0",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-keyboard-controller": "1.18.5",
    "react-native-reanimated": "4.1.7",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1",
    "tailwind-merge": "^3.4.0",
    "tailwind-variants": "^3.2.2",
    "tailwindcss": "catalog:",
    "uniwind": "^1.4.0",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@app-catolico/config": "workspace:*",
    "@expo/ngrok": "^4.1.3",
    "@sentry/cli": "^2.55.0",
    "@types/node": "^24.10.0",
    "@types/react": "~19.1.17",
    "typescript": "^5"
  }
}
