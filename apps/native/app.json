{
  "expo": {
    "scheme": "safe",
    "userInterfaceStyle": "automatic",
    "orientation": "default",
    "backgroundColor": "#8B1A1A",
    "androidStatusBar": {
      "barStyle": "light-content",
      "translucent": true
    },
    "icon": "./assets/images/logo.png",
    "owner": "sqpaloma",
    "ios": {
      "bundleIdentifier": "com.safe-espiritual.safe",
      "supportsTablet": true,
      "icon": "./assets/images/logo.png",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.safe_espiritual.safe",
      "icon": "./assets/images/logo.png"
    },
    "web": {
      "bundler": "metro"
    },
    "name": "Safe",
    "slug": "safe",
    "plugins": [
      "expo-font",
      "expo-splash-screen",
      "expo-secure-store"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "1d4390f6-dbd9-43be-a343-3678212f92ae"
      }
    }
  }
}
