{
  "expo": {
    "scheme": "app-catolico",
    "userInterfaceStyle": "automatic",
    "orientation": "default",
    "owner": "upcraftcrew",
    "web": {
      "bundler": "metro"
    },
    "name": "app-catolico",
    "slug": "app-catolico",
    "plugins": [
      "expo-font",
      "expo-splash-screen",
      "expo-secure-store",
      "expo-image"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
